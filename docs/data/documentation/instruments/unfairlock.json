{"abstract":[{"text":"Low-level lock that allows waiters to block efficiently on contention.","type":"text"}],"metadata":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UnfairLock","kind":"identifier"}],"title":"UnfairLock","role":"symbol","symbolKind":"class","roleHeading":"Class","modules":[{"name":"Instruments"}],"externalID":"s:11Instruments10UnfairLockC","navigatorTitle":[{"kind":"identifier","text":"UnfairLock"}]},"identifier":{"url":"doc:\/\/instruments.Instruments\/documentation\/Instruments\/UnfairLock","interfaceLanguage":"swift"},"topicSections":[{"identifiers":["doc:\/\/instruments.Instruments\/documentation\/Instruments\/UnfairLock\/init()"],"anchor":"Initializers","title":"Initializers","generated":true},{"identifiers":["doc:\/\/instruments.Instruments\/documentation\/Instruments\/UnfairLock\/lock()","doc:\/\/instruments.Instruments\/documentation\/Instruments\/UnfairLock\/try()","doc:\/\/instruments.Instruments\/documentation\/Instruments\/UnfairLock\/unlock()","doc:\/\/instruments.Instruments\/documentation\/Instruments\/UnfairLock\/withLock(_:)"],"anchor":"Instance-Methods","title":"Instance Methods","generated":true},{"identifiers":["doc:\/\/instruments.Instruments\/documentation\/Instruments\/UnfairLock\/NSLocking-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations","generated":true}],"hierarchy":{"paths":[["doc:\/\/instruments.Instruments\/documentation\/Instruments"]]},"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"seeAlsoSections":[{"generated":true,"title":"List of Tools","identifiers":["doc:\/\/instruments.Instruments\/documentation\/Instruments\/BytesConstructibleNumber","doc:\/\/instruments.Instruments\/documentation\/Instruments\/Endianness","doc:\/\/instruments.Instruments\/documentation\/Instruments\/DebounceFunction","doc:\/\/instruments.Instruments\/documentation\/Instruments\/DebounceFunctionConfiguration","doc:\/\/instruments.Instruments\/documentation\/Instruments\/HexStringDataDecoder","doc:\/\/instruments.Instruments\/documentation\/Instruments\/HexStringDataDecoderError","doc:\/\/instruments.Instruments\/documentation\/Instruments\/LLDB","doc:\/\/instruments.Instruments\/documentation\/Instruments\/WeakShared","doc:\/\/instruments.Instruments\/documentation\/Instruments\/Pointer","doc:\/\/instruments.Instruments\/documentation\/Instruments\/SecureRandom","doc:\/\/instruments.Instruments\/documentation\/Instruments\/SecureRandomError","doc:\/\/instruments.Instruments\/documentation\/Instruments\/Timer","doc:\/\/instruments.Instruments\/documentation\/Instruments\/LineByLineReader","doc:\/\/instruments.Instruments\/documentation\/Instruments\/LinewiseReader","doc:\/\/instruments.Instruments\/documentation\/Instruments\/DelegatePool"],"anchor":"List-of-Tools"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/instruments\/unfairlock"]}],"relationshipsSections":[{"type":"conformsTo","identifiers":["doc:\/\/instruments.Instruments\/objc(pl)NSLocking","doc:\/\/instruments.Instruments\/s8SendableP","doc:\/\/instruments.Instruments\/s16SendableMetatypeP"],"title":"Conforms To","kind":"relationships"}],"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"UnfairLock"}],"languages":["swift"],"platforms":["iOS","iPadOS","Mac Catalyst"]}],"kind":"declarations"},{"content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"UnfairLock is an appropriate lock for cases where simple and lightweight mutual exclusion is","type":"text"},{"type":"text","text":" "},{"text":"needed. It can be intrusively stored inline in a data structure without needing a separate","type":"text"},{"type":"text","text":" "},{"type":"text","text":"allocation, reducing memory consumption and cost of indirection. For situations where something"},{"type":"text","text":" "},{"type":"text","text":"more sophisticated like condition waits or FIFO ordering is needed, use appropriate higher level"},{"type":"text","text":" "},{"type":"text","text":"APIs such as those from the pthread or dispatch subsystems."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The values stored in the lock should be considered opaque and implementation defined, they"},{"type":"text","text":" "},{"type":"text","text":"contain thread ownership information that the system may use to attempt to resolve priority"},{"type":"text","text":" "},{"type":"text","text":"inversions."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This lock must be unlocked from the same thread that locked it, attempts to unlock from a"},{"type":"text","text":" "},{"type":"text","text":"different thread will cause an assertion aborting the process."}]},{"type":"paragraph","inlineContent":[{"text":"This lock must not be accessed from multiple processes or threads via shared or multiply-mapped","type":"text"},{"text":" ","type":"text"},{"text":"memory, because the lock implementation relies on the address of the lock value and identity of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the owning process."}]},{"inlineContent":[{"type":"text","text":"The name ‘unfair’ indicates that there is no attempt at enforcing acquisition fairness, e.g. an"},{"type":"text","text":" "},{"type":"text","text":"unlocker can potentially immediately reacquire the lock before a woken up waiter gets an"},{"type":"text","text":" "},{"type":"text","text":"opportunity to attempt to acquire the lock. This is often advantageous for performance reasons,"},{"type":"text","text":" "},{"text":"but also makes starvation of waiters a possibility.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This lock is suitable as a drop-in replacement for the deprecated OSSpinLock, providing much"},{"type":"text","text":" "},{"type":"text","text":"better behavior under contention."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://instruments.Instruments/documentation/Instruments/SecureRandom":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SecureRandom","kind":"identifier"}],"abstract":[{"type":"text","text":"An object that provides you functionality to generate bytes or numbers in a secure way."}],"title":"SecureRandom","identifier":"doc:\/\/instruments.Instruments\/documentation\/Instruments\/SecureRandom","role":"symbol","url":"\/documentation\/instruments\/securerandom","kind":"symbol","navigatorTitle":[{"text":"SecureRandom","kind":"identifier"}],"type":"topic"},"doc://instruments.Instruments/documentation/Instruments/UnfairLock/withLock(_:)":{"url":"\/documentation\/instruments\/unfairlock\/withlock(_:)","abstract":[{"text":"Executes given code by wrapping it with ","type":"text"},{"code":"lock()","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"unlock()","type":"codeVoice"},{"text":" methods.","type":"text"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withLock"},{"kind":"text","text":"<"},{"text":"Result","kind":"genericParameter"},{"text":">(() ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Result","preciseIdentifier":"s:11Instruments10UnfairLockC04withC0yxxyKXEKlF6ResultL_xmfp","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"rethrows","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Result","preciseIdentifier":"s:11Instruments10UnfairLockC04withC0yxxyKXEKlF6ResultL_xmfp","kind":"typeIdentifier"}],"kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/instruments.Instruments\/documentation\/Instruments\/UnfairLock\/withLock(_:)","title":"withLock(_:)"},"doc://instruments.Instruments/documentation/Instruments/BytesConstructibleNumber":{"t